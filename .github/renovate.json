{
  "extends": ["config:base"],
  "enabledManagers": ["dockerfile"],
  "dockerfile": {
    "fileMatch": ["(^|/)Dockerfile$"]
  },
  "packageRules": [
    {
      "managers": ["dockerfile"],
      "matchDatasources": ["docker"],
      "groupName": "Docker base image updates",
      "automerge": true,
      "automergeType": "branch"
    }
  ],
  "gitAuthor": "homelab-renovate <homelab-renovate@users.noreply.github.com>",
  "timezone": "UTC"
}
