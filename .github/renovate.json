{
  "extends": ["config:recommended"],
  "enabledManagers": ["dockerfile"],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)Dockerfile$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "dockerfile"
      ],
      "matchDatasources": ["docker"],
      "groupName": "Docker base image updates",
      "automerge": true,
      "automergeType": "branch"
    }
  ],
  "gitAuthor": "homelab-renovate <homelab-renovate@users.noreply.github.com>",
  "timezone": "UTC"
}
